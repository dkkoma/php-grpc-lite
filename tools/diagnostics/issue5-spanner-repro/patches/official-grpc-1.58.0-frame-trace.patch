+
+static void TraceOutboundFrameRecord(FILE* fp, const uint8_t header[9],
+                                     uint32_t frame_len, size_t chunk_len) {
+  const uint8_t type = header[3];
+  const uint8_t flags = header[4];
+  const uint32_t stream_id =
+      ((static_cast<uint32_t>(header[5]) & 0x7f) << 24) |
+      (static_cast<uint32_t>(header[6]) << 16) |
+      (static_cast<uint32_t>(header[7]) << 8) |
+      static_cast<uint32_t>(header[8]);
+  fprintf(fp,
+          "{\"monotonic_us\":%" PRIu64
+          ",\"pid\":%ld,\"event\":\"wire.frame_out\",\"transport\":\"official_ext_grpc\",\"stream_id\":%u,\"frame_type\":\"%s\",\"frame_type_id\":%u,\"flags\":%u,\"frame_payload_len\":%u,\"chunk_len\":%zu}\n",
+          MonotonicUs(), static_cast<long>(getpid()), stream_id,
+          FrameTypeName(type), static_cast<unsigned>(type),
+          static_cast<unsigned>(flags), frame_len, chunk_len);
+}
+
+static void TraceOutboundFrames(grpc_chttp2_transport* t) {
+  const char* path = getenv("GRPC_OFFICIAL_FRAME_TRACE_FILE");
+  if (path == nullptr || path[0] == '\0') return;
+  FILE* fp = fopen(path, "a");
+  if (fp == nullptr) return;
+  flock(fileno(fp), LOCK_EX);
+
+  uint8_t header[9];
+  size_t header_len = 0;
+  uint32_t payload_remaining = 0;
+  bool first_slice = true;
+
+  for (size_t slice_index = 0; slice_index < t->outbuf.count; slice_index++) {
+    const grpc_slice& slice = t->outbuf.slices[slice_index];
+    const uint8_t* data = GRPC_SLICE_START_PTR(slice);
+    size_t len = GRPC_SLICE_LENGTH(slice);
+    size_t offset = 0;
+
+    if (first_slice && len >= GRPC_CHTTP2_CLIENT_CONNECT_STRLEN &&
+        memcmp(data, GRPC_CHTTP2_CLIENT_CONNECT_STRING,
+               GRPC_CHTTP2_CLIENT_CONNECT_STRLEN) == 0) {
+      TraceConnectionPreface(fp, GRPC_CHTTP2_CLIENT_CONNECT_STRLEN);
+      offset = GRPC_CHTTP2_CLIENT_CONNECT_STRLEN;
+    }
+    first_slice = false;
+
+    while (offset < len) {
+      if (payload_remaining > 0) {
+        const size_t skip =
+            std::min(static_cast<size_t>(payload_remaining), len - offset);
+        payload_remaining -= static_cast<uint32_t>(skip);
+        offset += skip;
+        continue;
+      }
+
+      const size_t needed = sizeof(header) - header_len;
+      const size_t take = std::min(needed, len - offset);
+      memcpy(header + header_len, data + offset, take);
+      header_len += take;
+      offset += take;
+
+      if (header_len == sizeof(header)) {
+        const uint32_t frame_len = (static_cast<uint32_t>(header[0]) << 16) |
+                                   (static_cast<uint32_t>(header[1]) << 8) |
+                                   static_cast<uint32_t>(header[2]);
+        TraceOutboundFrameRecord(fp, header, frame_len,
+                                 static_cast<size_t>(frame_len) +
+                                     sizeof(header));
+        payload_remaining = frame_len;
+        header_len = 0;
+      }
+    }
+  }
+
+  if (header_len != 0 || payload_remaining != 0) {
+    fprintf(fp,
+            "{\"monotonic_us\":%" PRIu64
+            ",\"pid\":%ld,\"event\":\"wire.chunk_unparsed\",\"transport\":\"official_ext_grpc\",\"header_len\":%zu,\"payload_remaining\":%u}\n",
+            MonotonicUs(), static_cast<long>(getpid()), header_len,
+            payload_remaining);
+  }
+
+  flock(fileno(fp), LOCK_UN);
+  fclose(fp);
+}
