+static void TraceConnectionPreface(FILE* fp, size_t chunk_len) {
+  fprintf(fp,
+          "{\"monotonic_us\":%" PRIu64
+          ",\"pid\":%ld,\"event\":\"wire.connection_preface\",\"transport\":\"official_ext_grpc\",\"chunk_len\":%zu}\n",
