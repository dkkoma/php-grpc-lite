diff --git a/lib/http2.c b/lib/http2.c
index dd82aa9..8d2a770 100644
--- a/lib/http2.c
+++ b/lib/http2.c
@@ -830,6 +830,8 @@ static ssize_t send_callback(nghttp2_session *h2,
                                     nw_out_writer, cf, &result);
   if(nwritten < 0) {
     if(result == CURLE_AGAIN) {
+      infof(data, "[CURLINST] h2_send_callback blocked blen=%zu outbuf=%zu",
+            blen, Curl_bufq_len(&ctx->outbufq));
       ctx->nw_out_blocked = 1;
       return NGHTTP2_ERR_WOULDBLOCK;
     }
@@ -838,9 +840,13 @@ static ssize_t send_callback(nghttp2_session *h2,
   }

   if(!nwritten) {
+    infof(data, "[CURLINST] h2_send_callback wrote_zero blen=%zu outbuf=%zu",
+          blen, Curl_bufq_len(&ctx->outbufq));
     ctx->nw_out_blocked = 1;
     return NGHTTP2_ERR_WOULDBLOCK;
   }
+  infof(data, "[CURLINST] h2_send_callback blen=%zu wrote=%zd outbuf=%zu",
+        blen, nwritten, Curl_bufq_len(&ctx->outbufq));
   return nwritten;
 }

@@ -1217,6 +1223,11 @@ static CURLcode on_stream_frame(struct Curl_cfilter *cf,
     drain_stream(cf, data, stream);
     break;
   case NGHTTP2_WINDOW_UPDATE:
+    infof(data, "[CURLINST] h2_window_update stream=%d incr=%d want_send=%d "
+          "stream_sendbuf=%zu conn_outbuf=%zu",
+          frame->hd.stream_id, frame->window_update.window_size_increment,
+          CURL_WANT_SEND(data) ? 1 : 0,
+          Curl_bufq_len(&stream->sendbuf), Curl_bufq_len(&ctx->outbufq));
     if(CURL_WANT_SEND(data) && Curl_bufq_is_empty(&stream->sendbuf)) {
       /* need more data, force processing of transfer */
       drain_stream(cf, data, stream);
@@ -1810,6 +1821,11 @@ static ssize_t req_body_read_callback(nghttp2_session *session,
     nread = 0;
   }

+  infof(data_s, "[CURLINST] h2_req_body_read stream=%d want=%zu nread=%zd "
+        "body_eos=%d sendbuf=%zu result=%d",
+        stream_id, length, nread, stream->body_eos ? 1 : 0,
+        Curl_bufq_len(&stream->sendbuf), result);
+
   CURL_TRC_CF(data_s, cf, "[%d] req_body_read(len=%zu) eos=%d -> %zd, %d",
               stream_id, length, stream->body_eos, nread, result);

@@ -2245,6 +2261,11 @@ static ssize_t cf_h2_body_send(struct Curl_cfilter *cf,
   if(nwritten < 0)
     return -1;

+  infof(data, "[CURLINST] h2_body_send stream=%d len=%zu wrote=%zd eos=%d "
+        "body_eos=%d sendbuf=%zu err=%d",
+        stream->id, blen, nwritten, eos ? 1 : 0,
+        stream->body_eos ? 1 : 0, Curl_bufq_len(&stream->sendbuf), *err);
+
   if(eos && (blen == (size_t)nwritten))
     stream->body_eos = TRUE;

@@ -2424,6 +2445,14 @@ static ssize_t cf_h2_send(struct Curl_cfilter *cf, struct Curl_easy *data,
   /* Call the nghttp2 send loop and flush to write ALL buffered data,
    * headers and/or request body completely out to the network */
   result = h2_progress_egress(cf, data);
+  if(stream) {
+    infof(data, "[CURLINST] h2_progress_egress stream=%d result=%d "
+          "stream_window=%d conn_window=%d sendbuf=%zu outbuf=%zu",
+          stream->id, result,
+          nghttp2_session_get_stream_remote_window_size(ctx->h2, stream->id),
+          nghttp2_session_get_remote_window_size(ctx->h2),
+          Curl_bufq_len(&stream->sendbuf), Curl_bufq_len(&ctx->outbufq));
+  }

   /* if the stream has been closed in egress handling (nghttp2 does that
    * when it does not like the headers, for example */
