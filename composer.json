{
    "name": "dkkoma/php-grpc-lite",
    "description": "Source-built grpc extension for PHP: php-grpc-lite HTTP/2 transport drop-in candidate for ext-grpc",
    "type": "php-ext",
    "license": "MIT",
    "homepage": "https://github.com/dkkoma/php-grpc-lite",
    "keywords": [
        "grpc",
        "http2",
        "php-extension",
        "pie"
    ],
    "support": {
        "issues": "https://github.com/dkkoma/php-grpc-lite/issues",
        "source": "https://github.com/dkkoma/php-grpc-lite"
    },
    "require": {
        "php": ">=8.4"
    },
    "require-dev": {
        "grpc/grpc": "^1.80",
        "google/cloud-spanner": "^2.6",
        "google/protobuf": "^4.0",
        "phpunit/phpunit": "^11.0"
    },
    "suggest": {
        "ext-protobuf": "Use the protobuf C extension for faster serialization",
        "grpc/grpc": "Install the official PHP wrapper package in applications that use generated stubs or gax clients",
        "open-telemetry/api": "Inject the active application trace context into gRPC metadata"
    },
    "autoload": {
        "psr-4": {
            "GrpcLite\\": "support/php/GrpcLite/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "PhpGrpcLite\\Tests\\": "tests/",
            "PhpGrpcLite\\Bench\\": "bench/",
            "Helloworld\\": "tests/fixtures/Generated/Helloworld/",
            "GPBMetadata\\": "tests/fixtures/Generated/GPBMetadata/"
        }
    },
    "config": {
        "sort-packages": true,
        "preferred-install": "dist",
        "platform": {
            "ext-grpc": "1.62.0"
        }
    },
    "php-ext": {
        "extension-name": "grpc",
        "build-path": ".",
        "support-nts": true,
        "support-zts": true
    }
}
