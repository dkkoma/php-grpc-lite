{
    "name": "php-grpc-lite/php-grpc-lite",
    "description": "ext-grpc drop-in replacement candidate: PHP gRPC client with source-build native transport",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": ">=8.4"
    },
    "provide": {
        "ext-grpc": "1.62.0"
    },
    "require-dev": {
        "google/cloud-spanner": "^2.6",
        "google/protobuf": "^4.0",
        "phpbench/phpbench": "^1.6",
        "phpunit/phpunit": "^11.0"
    },
    "suggest": {
        "ext-protobuf": "Use the protobuf C extension for faster serialization",
        "ext-grpc": "Build and load this repository's ext/grpc source as grpc.so before relying on the ext-grpc provide entry"
    },
    "autoload": {
        "psr-4": {
            "Grpc\\": "src/Grpc/"
        },
        "files": [
            "src/Grpc/constants.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "PhpGrpcLite\\Tests\\": "tests/",
            "PhpGrpcLite\\Bench\\": "bench/",
            "Helloworld\\": "tests/fixtures/Generated/Helloworld/",
            "GPBMetadata\\": "tests/fixtures/Generated/GPBMetadata/"
        }
    },
    "config": {
        "sort-packages": true,
        "preferred-install": "dist",
        "platform": {
            "ext-grpc": "1.62.0"
        }
    }
}
